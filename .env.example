# Open Managed Agents — docker compose 环境变量（可选）
# 复制此文件为 .env 并编辑后，docker compose 会自动加载。
#
# 所有变量都是可选的 —— compose 内置了合理的开发默认值。

# ---- 上游 Anthropic API（让 oma-server 调用 Claude）----
# ANTHROPIC_UPSTREAM_API_KEY=sk-ant-...
# ANTHROPIC_UPSTREAM_BASE_URL=https://your-proxy.example.com

# ---- 前端访问端口 ----
# Caddy 监听端口（默认 28080）。端口冲突时可改为其他端口，或设为 0 使用随机端口。
# CADDY_HOST_PORT=28080
