#!/usr/bin/env bash
set -euo pipefail

ANT_BIN="${ANT_BIN:-/Users/arthur/GolandProjects/anthropic-sdk-all/anthropic-cli/ant}"
ANT_BASE_URL="${ANT_BASE_URL:-http://localhost:38080}"
ANT_API_KEY="${ANT_API_KEY:-sk-ant-api03-XuCxmIM_sikQZNITUgn96BcR301063m581U9yzlTzB0}"
ANT_FILES_BETA="${ANT_FILES_BETA:-files-api-2025-04-14}"
ANT_FORMAT="${ANT_FORMAT:-json}"
ANT_SCRUB_BASE_URL="${ANT_SCRUB_BASE_URL:-1}"
ANT_SCRUB_AUTH_TOKEN="${ANT_SCRUB_AUTH_TOKEN:-1}"

usage() {
  cat <<'EOF'
Usage:
  scripts/upload-platform-files [--dry-run] [--list-after] [--] [file ...]

Uploads files into the local Claude API Server workspace on localhost:38080.
If no files are provided, the script creates and uploads three small sample
files.

Defaults:
  ANT_BIN=/Users/arthur/GolandProjects/anthropic-sdk-all/anthropic-cli/ant
  ANT_BASE_URL=http://localhost:38080
  ANT_API_KEY=sk-ant-local-default
  ANT_FILES_BETA=files-api-2025-04-14
  ANT_FORMAT=json
  ANT_SCRUB_BASE_URL=1
  ANT_SCRUB_AUTH_TOKEN=1

Examples:
  scripts/upload-platform-files
  scripts/upload-platform-files ./notes.md ./sample.json
  ANT_BASE_URL=http://127.0.0.1:38080 scripts/upload-platform-files ./notes.md

Auth:
  Defaults to the local seed key sk-ant-local-default. Override ANT_API_KEY
  if you need to target a different local workspace.
EOF
}

die() {
  echo "upload-platform-files: $*" >&2
  echo >&2
  usage >&2
  exit 2
}

dry_run=0
list_after=0
files=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --list-after)
      list_after=1
      shift
      ;;
    --)
      shift
      files+=("$@")
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      files+=("$1")
      shift
      ;;
  esac
done

[[ -x "$ANT_BIN" ]] || die "ANT_BIN is not executable: $ANT_BIN"

tmp_dir=""
cleanup() {
  if [[ -n "$tmp_dir" && -d "$tmp_dir" ]]; then
    rm -rf "$tmp_dir"
  fi
}
trap cleanup EXIT

if [[ ${#files[@]} -eq 0 ]]; then
  tmp_dir="$(mktemp -d)"
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"

  notes_file="$tmp_dir/claude-files-smoke-$stamp-notes.txt"
  json_file="$tmp_dir/claude-files-smoke-$stamp-metadata.json"
  md_file="$tmp_dir/claude-files-smoke-$stamp-readme.md"

  printf 'Claude Platform Files API smoke upload\ncreated_at=%s\n' "$stamp" >"$notes_file"
  printf '{\n  "kind": "files-api-smoke",\n  "created_at": "%s",\n  "source": "scripts/upload-platform-files"\n}\n' "$stamp" >"$json_file"
  printf '# Files API smoke upload\n\nGenerated by `scripts/upload-platform-files` at `%s`.\n' "$stamp" >"$md_file"

  files=("$notes_file" "$json_file" "$md_file")
fi

env_cmd=(env)
if [[ "$ANT_SCRUB_BASE_URL" != "0" ]]; then
  env_cmd+=(-u ANTHROPIC_BASE_URL)
fi
if [[ "$ANT_SCRUB_AUTH_TOKEN" != "0" ]]; then
  env_cmd+=(-u ANTHROPIC_AUTH_TOKEN)
fi

ant_base=("$ANT_BIN" --base-url "$ANT_BASE_URL" --api-key "$ANT_API_KEY" --format "$ANT_FORMAT")
files_args=(--beta "$ANT_FILES_BETA")

echo "Using ant: $ANT_BIN" >&2
echo "Using API base URL: $ANT_BASE_URL" >&2
echo "Using local API key: ${ANT_API_KEY:0:12}..." >&2
echo "Using beta header: $ANT_FILES_BETA" >&2
echo >&2

for file in "${files[@]}"; do
  [[ -f "$file" ]] || die "file does not exist or is not a regular file: $file"

  echo "Uploading: $file" >&2
  if [[ "$dry_run" == "1" ]]; then
    printf 'DRY RUN:'
    printf ' %q' "${env_cmd[@]}" "${ant_base[@]}" beta:files upload --file "$file" "${files_args[@]}"
    printf '\n'
  else
    "${env_cmd[@]}" "${ant_base[@]}" beta:files upload --file "$file" "${files_args[@]}"
  fi
  echo >&2
done

if [[ "$list_after" == "1" ]]; then
  echo "Listing latest files:" >&2
  if [[ "$dry_run" == "1" ]]; then
    printf 'DRY RUN:'
    printf ' %q' "${env_cmd[@]}" "${ant_base[@]}" beta:files list --limit 20 "${files_args[@]}"
    printf '\n'
  else
    "${env_cmd[@]}" "${ant_base[@]}" beta:files list --limit 20 "${files_args[@]}"
  fi
fi
